# Asset binaries — never commit (sidecar .yaml files are tracked).
# SVGs live inside skill/assets/ but their binary content stays private.
# Raster binaries live OUTSIDE the skill in ../assets-external/ and are
# never near the repo anyway, but we add a safety net here for the case
# where someone accidentally drops one into skill/assets/.
skill/assets/*.svg
skill/assets/*.png
skill/assets/*.jpg
skill/assets/*.jpeg
skill/assets/*.webp
skill/assets/*.gif
skill/assets/*.tiff
skill/assets/*.bmp

# Template opening slide — pre-rendered .pptx the renderer prepends to
# every deck. Each machine / org keeps its own; never commit.
skill/templates/*.pptx

__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
.env
.DS_Store
.idea/
.vscode/
dist/
build/
*.egg
out/
*.pptx
!tests/fixtures/*.pptx
.warnings.txt
